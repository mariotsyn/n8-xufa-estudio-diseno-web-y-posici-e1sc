---
interface Props { title: string; text: string; imageUrl: string; }
const { title, text, imageUrl } = Astro.props;
---
<section id="about" style="background:var(--color-bg);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr;gap:4rem;align-items:center;" class="about-grid">
      <div class="reveal img-hover" style="border-radius:24px;overflow:hidden;aspect-ratio:4/3;">
        <img src={imageUrl} alt="Sobre nosotros" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
      </div>
      <div class="reveal">
        <span style="display:inline-block;padding:6px 16px;border-radius:50px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);color:var(--color-primary);font-size:0.8rem;font-weight:600;margin-bottom:1rem;text-transform:uppercase;letter-spacing:1px;">
          Conócenos
        </span>
        <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;margin-bottom:1.5rem;letter-spacing:-1px;">
          {title}
        </h2>
        <div style="color:var(--color-text-muted);line-height:1.9;font-size:1rem;" set:html={text.replace(/\n/g, '<br/><br/>')} />
      </div>
    </div>
  </div>
</section>
<style>
  @media(min-width:768px) { .about-grid { grid-template-columns: 1fr 1fr !important; } }
</style>