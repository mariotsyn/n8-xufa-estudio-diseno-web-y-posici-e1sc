---
interface Props {
  title: string;
  subtitle?: string;
  phone?: string;
  email?: string;
  address?: string;
  whatsappNumber?: string;
  hours?: string[];
  mapQuery?: string;
}
const { title, subtitle, phone, email, address, whatsappNumber, hours, mapQuery } = Astro.props;
const waLink = whatsappNumber ? `https://wa.me/${whatsappNumber.replace(/[^0-9]/g, '')}` : null;
---
<section id="contact" style="background:var(--color-bg);position:relative;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at bottom, color-mix(in srgb, var(--color-primary) 8%, transparent) 0%, transparent 70%);pointer-events:none;"></div>
  <div class="container" style="position:relative;z-index:2;">
    <div class="reveal" style="text-align:center;margin-bottom:4rem;">
      <span style="display:inline-block;padding:6px 16px;border-radius:50px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);color:var(--color-primary);font-size:0.8rem;font-weight:600;margin-bottom:1rem;text-transform:uppercase;letter-spacing:1px;">
        Contacto
      </span>
      <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(1.8rem,4vw,3rem);font-weight:800;letter-spacing:-1px;">
        {title}
      </h2>
      {subtitle && <p style="color:var(--color-text-muted);margin-top:1rem;font-size:1.05rem;">{subtitle}</p>}
    </div>
    
    <div style="display:grid;grid-template-columns:1fr;gap:2rem;" class="contact-grid">
      <!-- Contact info cards -->
      <div class="reveal" style="display:grid;grid-template-columns:1fr;gap:1rem;">
        {phone && (
          <a href={`tel:${phone}`} class="bento-card" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:1.2rem;padding:1.5rem;">
            <div style="width:48px;height:48px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">📞</div>
            <div><p style="font-size:0.75rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Teléfono</p><p style="font-weight:600;">{phone}</p></div>
          </a>
        )}
        {email && (
          <a href={`mailto:${email}`} class="bento-card" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:1.2rem;padding:1.5rem;">
            <div style="width:48px;height:48px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">📧</div>
            <div><p style="font-size:0.75rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Email</p><p style="font-weight:600;">{email}</p></div>
          </a>
        )}
        {address && (
          <div class="bento-card" style="display:flex;align-items:center;gap:1.2rem;padding:1.5rem;">
            <div style="width:48px;height:48px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">📍</div>
            <div><p style="font-size:0.75rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Dirección</p><p style="font-weight:600;">{address}</p></div>
          </div>
        )}
        {hours && hours.length > 0 && (
          <div class="bento-card" style="display:flex;align-items:flex-start;gap:1.2rem;padding:1.5rem;">
            <div style="width:48px;height:48px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">🕐</div>
            <div><p style="font-size:0.75rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Horarios</p>{hours.map(h => <p style="font-weight:500;font-size:0.9rem;line-height:1.7;">{h}</p>)}</div>
          </div>
        )}
      </div>
      
      <!-- CTA or Map -->
      <div class="reveal">
        {waLink && (
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-glow" style="width:100%;justify-content:center;padding:18px;font-size:1.1rem;border-radius:16px;margin-bottom:1.5rem;background:#25D366;">
            💬 Escríbenos por WhatsApp
          </a>
        )}
        {mapQuery && (
          <div style="border-radius:20px;overflow:hidden;border:1px solid var(--color-border);aspect-ratio:16/9;">
            <iframe
              src={`https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`}
              style="width:100%;height:100%;border:0;filter:invert(0.9) hue-rotate(180deg) saturate(0.6) brightness(0.8);"
              loading="lazy"
              allowfullscreen
            ></iframe>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
<style>
  @media(min-width:768px) { .contact-grid { grid-template-columns: 1fr 1fr !important; } }
</style>