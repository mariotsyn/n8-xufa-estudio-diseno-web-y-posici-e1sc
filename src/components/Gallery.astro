---
interface GalleryItem { url: string; alt: string; }
interface Props { gallery: GalleryItem[]; title?: string; }
const { gallery, title = 'Galería' } = Astro.props;
---
<section id="gallery" style="background:var(--color-bg);">
  <div class="container">
    <div class="reveal" style="text-align:center;margin-bottom:4rem;">
      <span style="display:inline-block;padding:6px 16px;border-radius:50px;background:color-mix(in srgb, var(--color-primary) 15%, transparent);color:var(--color-primary);font-size:0.8rem;font-weight:600;margin-bottom:1rem;text-transform:uppercase;letter-spacing:1px;">
        Galería
      </span>
      <h2 style="font-family:'Outfit',sans-serif;font-size:clamp(1.8rem,4vw,3rem);font-weight:800;letter-spacing:-1px;">
        {title}
      </h2>
    </div>
    
    <div class="reveal gallery-grid">
      {gallery.map((item, i) => (
        <div class="img-hover" data-stagger style={`${i === 0 ? 'grid-row:span 2;' : ''}transition-delay:${i * 0.08}s;`}>
          <img src={item.url} alt={item.alt} style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .gallery-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;border-radius:20px;overflow:hidden; }
  @media(min-width:768px) { .gallery-grid { grid-template-columns:repeat(3,1fr);gap:1.2rem; } }
  .gallery-grid .img-hover { border-radius:16px;aspect-ratio:1;overflow:hidden; }
  .gallery-grid .img-hover:first-child { aspect-ratio:auto; }
</style>