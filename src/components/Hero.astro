---
interface Props {
  headline: string;
  subheadline: string;
  cta1: { text: string; href: string };
  cta2?: { text: string; href: string };
  imageUrl: string;
  rating?: number;
  reviewCount?: number;
}
const { headline, subheadline, cta1, cta2, imageUrl, rating, reviewCount } = Astro.props;
---
<section id="hero" style="position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:0;">
  <div style={`position:absolute;inset:0;background:url('${imageUrl}') center/cover no-repeat;`}></div>
  <div style="position:absolute;inset:0;background:linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.7) 100%);"></div>
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom, transparent 60%, var(--color-bg) 100%);"></div>
  
  <div class="container" style="position:relative;z-index:10;text-align:center;padding:2rem 1.5rem;max-width:900px;">
    {rating && (
      <div class="reveal" style="margin-bottom:1.5rem;display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:50px;background:rgba(255,255,255,0.08);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.1);">
        <span class="stars">{'★'.repeat(Math.round(rating))}</span>
        <span style="font-size:0.85rem;color:rgba(255,255,255,0.8);">{rating} · {reviewCount || '50+'} reseñas</span>
      </div>
    )}
    
    <h1 class="reveal" style="font-family:'Outfit',sans-serif;font-size:clamp(2.2rem,6vw,4.5rem);font-weight:900;line-height:1.05;margin-bottom:1.5rem;letter-spacing:-1.5px;">
      {headline}
    </h1>
    
    <p class="reveal" style="font-size:clamp(1rem,2.5vw,1.3rem);color:rgba(255,255,255,0.7);max-width:600px;margin:0 auto 2.5rem;line-height:1.7;font-weight:300;">
      {subheadline}
    </p>
    
    <div class="reveal" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href={cta1.href} class="btn-glow">{cta1.text}</a>
      {cta2 && <a href={cta2.href} class="btn-outline">{cta2.text}</a>}
    </div>
  </div>
  
  <div style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:10;">
    <div style="width:24px;height:40px;border:2px solid rgba(255,255,255,0.3);border-radius:12px;display:flex;justify-content:center;padding-top:8px;">
      <div style="width:3px;height:8px;background:rgba(255,255,255,0.6);border-radius:2px;animation:slideUp 1.5s ease-in-out infinite;"></div>
    </div>
  </div>
</section>