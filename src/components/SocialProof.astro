---
interface Props { rating: number; reviewCount: number; businessName: string; }
const { rating, reviewCount, businessName } = Astro.props;
---
<div class="reveal" style="padding:2rem 1.5rem;background:var(--color-bg-card);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
  <div class="container" style="display:flex;align-items:center;justify-content:center;gap:2rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.8rem;">
      <div style="display:flex;align-items:center;gap:2px;">
        {[1,2,3,4,5].map(i => (
          <svg key={i} width="20" height="20" viewBox="0 0 20 20" fill={i <= Math.round(rating) ? '#fbbf24' : '#374151'}>
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <span style="font-weight:700;font-size:1.1rem;">{rating}</span>
    </div>
    <span style="color:var(--color-text-muted);font-size:0.9rem;">Basado en <strong style="color:white;">{reviewCount}+</strong> reseñas de Google</span>
  </div>
</div>